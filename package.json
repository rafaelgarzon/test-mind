{
  "name": "automation-front-ai",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:run": "npx cucumber-js --require-module ts-node/register --format @serenity-js/cucumber --require features/support/setup.ts --require features/step_definitions/**/*.ts features/**/*.feature",
    "report": "serenity-bdd run",
    "test": "npm run test:run && npm run report",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "playwright:report": "npx playwright show-report",
    "ai:gen": "npx ts-node src/ai/generator.ts",
    "ai:cli": "npx ts-node src/cli/index.ts",
    "ai:web": "npx ts-node src/ui/server.ts",
    "clean": "rm -rf test-results playwright-report target",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@serenity-js/assertions": "^3.38.0",
    "@serenity-js/console-reporter": "^3.38.0",
    "@serenity-js/core": "^3.38.0",
    "@serenity-js/playwright": "^3.38.0",
    "@serenity-js/web": "^3.38.0",
    "axios": "^1.13.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "inquirer": "^13.2.2",
    "openai": "^6.17.0",
    "playwright": "^1.58.0",
    "sqlite3": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@playwright/test": "^1.58.0",
    "@serenity-js/cucumber": "^3.38.0",
    "@serenity-js/serenity-bdd": "^3.38.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.1.0",
    "@types/sqlite3": "^3.1.11",
    "@vitest/coverage-v8": "^4.0.18",
    "ts-node": "^10.9.2",
    "vitest": "^4.0.18"
  }
}
