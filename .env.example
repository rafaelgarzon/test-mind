# ─────────────────────────────────────────────────────────────────────────────
# Automation Front AI — Variables de entorno
# Copia este archivo como .env y ajusta los valores según tu entorno.
# ─────────────────────────────────────────────────────────────────────────────

# ── Proveedor de IA ────────────────────────────────────────────────────────
# Opciones: 'ollama' (local, por defecto) | 'openai' (cloud)
AI_PROVIDER=ollama

# ── Modelo de chat / generación ────────────────────────────────────────────
# El modelo que usan RequirementsAgent, BusinessAlignmentAgent y CodeGeneratorAgent.
#
# Recomendaciones por hardware disponible (vía Ollama):
#
#   Hardware   │ Modelo recomendado       │ VRAM (Q4) │ Notas
#   ───────────┼──────────────────────────┼───────────┼──────────────────────
#   ≥ 24 GB    │ qwen3:32b                │ ~20 GB    │ Mejor calidad general
#   16–22 GB   │ qwen3:30b-a3b            │ ~17 GB    │ MoE, activa 3B/token
#   8–14 GB    │ qwen3:14b                │ ~10 GB    │ Punto óptimo portátil
#   < 8 GB     │ qwen3:8b                 │ ~6 GB     │ Mínimo funcional
#   (cloud)    │ gpt-4o                   │  —        │ Requiere OPENAI_API_KEY
#
# Nota: para usar Gemma 4, reemplaza con gemma4:4b / gemma4:27b (menor calidad
# en TypeScript y bilingüismo ES/EN vs Qwen3).
AI_MODEL=qwen3:14b

# ── Modelo de embeddings (ChromaDB / deduplicación semántica) ──────────────
# IMPORTANTE: mantener este modelo estable. Si lo cambias, debes limpiar
# ChromaDB para evitar inconsistencias en los vectores almacenados:
#   docker-compose down -v chromadb && docker-compose up -d chromadb
#
# Opciones:
#   bge-m3            — 72% recall semántico, 100+ idiomas (recomendado)
#   nomic-embed-text  — más ligero (~500 MB), 57% recall
EMBEDDING_MODEL=bge-m3

# ── OpenAI (solo si AI_PROVIDER=openai) ───────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Ollama (solo si no usas Docker Compose) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Servidor ───────────────────────────────────────────────────────────────
PORT=3000

# ── Playwright MCP ─────────────────────────────────────────────────────────
PREVIEW_BROWSER=chromium
PREVIEW_HEADLESS=true

# ── Auto-implementación ────────────────────────────────────────────────────
# Ruta absoluta donde se escriben los .feature y .steps.ts generados.
# Si se omite, se usa ./features por defecto.
# IMPLEMENT_FEATURES_DIR=/ruta/absoluta/a/tu/proyecto/features
